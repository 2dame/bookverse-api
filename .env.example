# Environment Variables — Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookverse_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Authentication — generate a strong random secret for production
JWT_SECRET=replace_this_with_a_strong_random_secret
JWT_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:3000
